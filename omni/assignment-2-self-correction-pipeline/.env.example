# Required
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority"

# Server
PORT=3000

# Demo / grading friendliness:
# - true  => deterministic mock extraction + mock critic (no external LLM calls)
# - false => uses OpenAI (requires OPENAI_API_KEY)
MOCK_LLM=true

# Optional real LLM mode (set MOCK_LLM=false)
OPENAI_API_KEY=""
OPENAI_EXTRACT_MODEL="gpt-4o-mini"
OPENAI_CRITIC_MODEL="gpt-4o-mini"

# Optional DB name
# (defaults to "assignment2")
# MONGODB_DB="assignment2"

